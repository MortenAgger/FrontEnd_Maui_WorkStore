<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="fwd_bilvaerksted.Pages.MainPage"
             xmlns:vm="clr-namespace:fwd_bilvaerksted.ViewModels">
    <VerticalStackLayout Padding="20" Spacing="16">
        <Label Text="Bilværksted" Style="{StaticResource Headline}" />
        <Label Text="Vælg en handling nedenfor:" Style="{StaticResource SubHeadline}" />
        <Button Text="Book ny opgave" Command="{Binding BookNewOrderCommand}" />
        <Button Text="Oversigt over opgaver for en dato" Command="{Binding GoToOrderOverviewCommand}" />
        <Button Text="Opret faktura" Command="{Binding GoToCreateInvoiceCommand}" />
        <Button Text="Se fakturaer" Command="{Binding GoToViewInvoicesCommand}" />
    </VerticalStackLayout>
</ContentPage>
