<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="fwd_bilvaerksted.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:fwd_bilvaerksted.Pages"
    Title="Bilværksted">

    <ShellContent Title="Hjem" ContentTemplate="{DataTemplate pages:MainPage}" Route="MainPage" />
    <ShellContent Title="Book opgave" ContentTemplate="{DataTemplate pages:BookWorkOrder}" Route="BookWorkOrder" />
    <ShellContent Title="Oversigt" ContentTemplate="{DataTemplate pages:OrderOverviewPage}" Route="OrderOverview" />
    <ShellContent Title="Opret faktura" ContentTemplate="{DataTemplate pages:CreateInvoicePage}" Route="CreateInvoice" />
    <ShellContent Title="Se fakturaer" ContentTemplate="{DataTemplate pages:ViewInvoicesPage}" Route="ViewInvoices" />
</Shell>
